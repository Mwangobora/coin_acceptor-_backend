model alerts {
  id                                          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  station_id                                  String             @db.Uuid
  device_id                                   String?            @db.Uuid
  locker_id                                   String?            @db.Uuid
  charging_port_id                            String?            @db.Uuid
  charging_session_id                         String?            @db.Uuid
  device_event_id                             String?            @db.Uuid
  alert_code                                  String             @db.VarChar(80)
  category                                    String             @db.VarChar(30)
  severity                                    String             @db.VarChar(20)
  title                                       String             @db.VarChar(160)
  message                                     String
  status                                      String             @default("open") @db.VarChar(20)
  deduplication_key                           String?            @db.VarChar(180)
  detected_at                                 DateTime           @db.Timestamptz(6)
  acknowledged_at                             DateTime?          @db.Timestamptz(6)
  acknowledged_by_user_id                     String?            @db.Uuid
  resolved_at                                 DateTime?          @db.Timestamptz(6)
  resolved_by_user_id                         String?            @db.Uuid
  resolution_notes                            String?
  metadata                                    Json               @default("{}")
  created_at                                  DateTime           @default(now()) @db.Timestamptz(6)
  updated_at                                  DateTime           @default(now()) @db.Timestamptz(6)
  users_alerts_acknowledged_by_user_idTousers users?             @relation("alerts_acknowledged_by_user_idTousers", fields: [acknowledged_by_user_id], references: [id], onUpdate: NoAction, map: "fk_alerts_acknowledged_by")
  device_events                               device_events?     @relation(fields: [device_event_id], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_alerts_device_event")
  devices                                     devices?           @relation(fields: [device_id, station_id], references: [id, station_id], onUpdate: NoAction, map: "fk_alerts_device_station")
  lockers                                     lockers?           @relation(fields: [locker_id, device_id], references: [id, device_id], onDelete: Restrict, onUpdate: NoAction, map: "fk_alerts_locker_device")
  charging_ports                              charging_ports?    @relation(fields: [charging_port_id, locker_id, device_id], references: [id, locker_id, device_id], onDelete: Restrict, onUpdate: NoAction, map: "fk_alerts_port_hierarchy")
  users_alerts_resolved_by_user_idTousers     users?             @relation("alerts_resolved_by_user_idTousers", fields: [resolved_by_user_id], references: [id], onUpdate: NoAction, map: "fk_alerts_resolved_by")
  charging_sessions                           charging_sessions? @relation(fields: [charging_session_id], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_alerts_session")
  stations                                    stations           @relation(fields: [station_id], references: [id], onUpdate: NoAction, map: "fk_alerts_station")

  @@index([station_id, status, detected_at(sort: Desc)], map: "idx_alerts_station_status")
}

