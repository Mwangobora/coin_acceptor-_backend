{
  "name": "coin_acceptor_backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"prisma/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test,prisma}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "check:lines": "node scripts/check-file-lines.mjs",
    "db:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/charging_system?schema=charging_system} prisma generate",
    "db:introspect": "node scripts/prisma-introspect.mjs",
    "db:schema:apply": "node scripts/apply-schema.mjs",
    "db:schema:verify": "node scripts/verify-database.mjs",
    "db:reset": "node scripts/reset-dev-database.mjs",
    "db:seed:core": "DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/charging_system?schema=charging_system} ts-node prisma/seed-core.ts",
    "db:seed:demo": "DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/charging_system?schema=charging_system} ts-node prisma/seed-demo.ts",
    "db:seed": "sh -c 'if [ \"$NODE_ENV\" = \"production\" ]; then echo \"Demo seed is disabled in production.\"; exit 1; fi; npm run db:seed:core && npm run db:seed:demo'",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "docker:logs": "docker compose logs -f",
    "docker:reset": "docker compose down -v"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/swagger": "^11.4.6",
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "eslint": "^10.7.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.5",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  }
}
