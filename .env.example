APP_NAME=charging-system-api
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
SWAGGER_ENABLED=true
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
DEVICE_AUTH_ENABLED=false
REQUEST_SIZE_LIMIT=1mb
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_TTL=7d
JWT_REFRESH_TTL=30d
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
AUTH_MIN_PASSWORD_LENGTH=12
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/charging_system?schema=charging_system
REDIS_URL=redis://localhost:6379
DEVICE_CREDENTIAL_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
DEVICE_HMAC_CLOCK_SKEW_SECONDS=300
DEVICE_EVENT_MAX_FUTURE_SECONDS=300
DEVICE_COMMAND_POLL_LIMIT=10
DEVICE_COMMAND_EXPIRY_INTERVAL_SECONDS=60
QR_PAYMENT_PROVIDER=mock
QR_MOCK_WEBHOOK_SECRET=development-mock-webhook-secret
QR_PAYMENT_EXPIRY_SECONDS=300
PAYMENT_PENDING_WINDOW_SECONDS=600
COIN_PULSE_MAPPING_JSON={"1":100,"2":200,"5":500,"10":1000}
SEED_ADMIN_NAME=System Administrator
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-this-development-password
BACKEND_PORT=4000
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=charging_system
