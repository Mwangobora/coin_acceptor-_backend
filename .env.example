APP_NAME=charging-system-api
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
SWAGGER_ENABLED=true
COOKIE_SECURE=false
DEVICE_AUTH_ENABLED=false
REQUEST_SIZE_LIMIT=1mb
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/charging_system?schema=charging_system
SEED_ADMIN_NAME=System Administrator
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-this-development-password
BACKEND_PORT=4000
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=charging_system
